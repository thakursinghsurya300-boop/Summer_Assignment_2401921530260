class Solution {
    public int diagonalSum(int[][] mat) {
    int m= mat.length;
    if(m==1) return mat[0][0];
    if(m==2) return (mat[0][0]+mat[0][1]+mat[1][0]+mat[1][1]);
    int sum=0;
    if(m%2==0)
    {
    for(int i=0;i<m;i++)
    {
        sum+=mat[i][i]+mat[i][m-i-1];
    }
    }
    else
    {
    for(int i=0;i<m;i++)
    {
        if(i==(m-i-1))
        sum+=mat[i][i];
        else
        sum+=mat[i][i]+mat[i][m-i-1];
    }
    }
    return sum;
    }
}
