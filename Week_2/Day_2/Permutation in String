class Solution {
    public boolean checkInclusion(String s1, String s2) {
     int[] freq = new int[26];
        int n=s2.length();
        int m=s1.length();
        for (int i = 0; i < n; i++) {
            freq[s2.charAt(i) - 'a']++;
        }
        for (int i = 0; i <m; i++) {
            int idx = s1.charAt(i) - 'a';
            if (freq[idx] == 0) {
                return false; 
            }
            freq[idx]--; 
        }
        return true;   
    }
}
